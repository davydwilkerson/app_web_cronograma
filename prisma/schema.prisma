generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ──────────────────────────────────────────────
// NEXT-AUTH (CORE)
// ──────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  // Campos extras para controle de sessão única
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  fingerprint  String?
  isActive     Boolean  @default(true) @map("is_active")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  role          String    @default("user") // admin, user, superadmin
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts         Account[]
  sessions         Session[]
  authorizedAccess AuthorizedAccess?
  trialUsage       TrialUsage?
  progress         UserProgress[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ──────────────────────────────────────────────
// SAAS LOGIC (ACCESS CONTROL)
// ──────────────────────────────────────────────

model AuthorizedAccess {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  email             String   @unique // Chave de vínculo com o pagamento
  status            String   // active, pending, blocked
  rawStatus         String?  @map("raw_status") // status original do HeroSpark
  blockReason       String?  @map("block_reason")
  planType          String?  @map("plan_type") // monthly, yearly, lifetime
  expiresAt         DateTime? @map("expires_at")
  lastPaymentDate   DateTime? @map("last_payment_date")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("authorized_access")
}

model TrialUsage {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  startedAt DateTime @default(now()) @map("started_at")
  expiresAt DateTime @map("expires_at")
  isActive  Boolean  @default(true) @map("is_active")
  converted Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trial_usage")
}

// ──────────────────────────────────────────────
// APP CONTENT (CRONOGRAMA)
// ──────────────────────────────────────────────

model WeekContent {
  id            Int      @id @default(autoincrement())
  weekNum       Int      @map("week_num")
  dayNum        Int      @map("day_num")
  cardOrder     Int      @default(1) @map("card_order")
  cardId        String   @map("card_id") // ex: "1-1"
  discipline    String
  title         String
  links         Json     @default("[]") // Links de estudo
  progressItems Json     @default("[]") @map("progress_items") // Itens (teoria, revisao...)
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([weekNum, dayNum, cardOrder])
  @@index([weekNum])
  @@map("week_content")
}

model UserProgress {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  weekNum      Int      @map("week_num")
  cardId       String   @map("card_id")
  isCompleted  Boolean  @default(false) @map("is_completed")
  progressData Json     @default("{}") @map("progress_data") // { teoria: 100, revisao: 0 }
  xpEarned     Int      @default(0) @map("xp_earned")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekNum, cardId])
  @@index([userId, weekNum])
  @@map("user_progress")
}
